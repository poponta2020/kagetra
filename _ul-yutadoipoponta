  <body data-haml=''>
    <div class='row' style='padding-top:8px;'>
      <div class='columns'>
        <a href='/mobile/'>[携帯用]</a>
        <a href='public/bbs'>[公開掲示板]</a>
        <a href='public/schedule'>[公開予定表]</a>
        <a href='public/result_list'>[入賞歴]</a>
        <a href='public/event_catalog'>[大会/行事案内]</a>
        <a href='public/wiki#page/41'>[役職]</a>
        <a href='public/wiki#page/15'>[練習会場]</a>
      </div>
    </div>
    <div id='container-shared-pass'></div>
    <div id='container-login'></div>
    <div id='container-board-message'></div>
    <script id='templ-shared-pass' type='text/template'>
      <div class='row'>
        <form class='large-6 columns' id='shared-pass'>
          <fieldset>
            <legend>ログイン</legend>
            <div class='row'>
              <div class='large-8 columns'>
                <label>共通パスワード</label>
                <div class='row collapse'>
                  <div class='large-10 small-10 columns'>
                    <input autofocus type='password'>
                  </div>
                  <div class='large-2 small-2 columns'>
                    <input class='button postfix radius' type='submit' value='GO'>
                  </div>
                </div>
              </div>
            </div>
          </fieldset>
        </form>
      </div>
    </script>
    <script id='templ-user-list' type='text/template'>
      <div class='row'>
        <div class='large-3 columns'>
          <select id='initials'>
            <option value='0'>あ行</option>
            <option value='1'>か行</option>
            <option value='2'>さ行</option>
            <option value='3'>た行</option>
            <option value='4'>な行</option>
            <option value='5'>は行</option>
            <option value='6'>ま行</option>
            <option value='7'>や行</option>
            <option value='8'>ら行</option>
            <option value='9'>わ行</option>
            <option value='-1'>その他</option>
          </select>
        </div>
        <div class='large-9 columns'>
          <select id='user-names'></select>
        </div>
      </div>
    </script>
    <script id='templ-login' type='text/template'>
      <div class='row'>
        <form class='large-6 columns' id='login'>
          <fieldset>
            <legend>ログイン</legend>
            <div id='user-list'></div>
            <div class='row'>
              <div class='large-8 columns'>
                <label>個人パスワード</label>
                <div class='row collapse'>
                  <div class='large-10 small-10 columns'>
                    <input autofocus type='password'>
                  </div>
                  <div class='large-2 small-2 columns'>
                    <input class='button postfix radius' type='submit' value='GO'>
                  </div>
                </div>
              </div>
            </div>
          </fieldset>
        </form>
      </div>
    </script>
    <script id='templ-board-message' type='text/template'>
      <div class='row'>
        <div class='columns'>
          <div class='message panel pre'>{{ _.replace_url_escape(data.message) }}</div>
        </div>
      </div>
    </script>
    <script>
      var g_shared_salt="58ME7KeMo1zCenH0BGtI8xlQq9vWkawe";
    </script>
